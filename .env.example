# ---------------------------------------------------------------------------
# App (required)
# ---------------------------------------------------------------------------
APP_NAME=Laravel
APP_ENV=local
# Generate with: docker compose run --rm app php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database – use these for Docker (matches docker-compose db service)
# ---------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=property_listing
DB_USERNAME=postgres
DB_PASSWORD=postgres

# For local dev without Docker you can use SQLite instead:
# DB_CONNECTION=sqlite
# DB_DATABASE=/var/www/html/database/database.sqlite

# Optional: DB_URL (overrides host/port/database/user/password), DB_CHARSET, DB_SSLMODE

# ---------------------------------------------------------------------------
# Session (database driver; sessions table created by migrations)
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ---------------------------------------------------------------------------
# Queue & cache (database driver for Docker)
# ---------------------------------------------------------------------------
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# ---------------------------------------------------------------------------
# Filesystem (local by default; S3 for production image uploads)
# ---------------------------------------------------------------------------
FILESYSTEM_DISK=local

# ---------------------------------------------------------------------------
# AWS S3 – required for property image uploads
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
# Optional for S3-compatible endpoints (e.g. LocalStack): AWS_URL=, AWS_ENDPOINT=

# ---------------------------------------------------------------------------
# Mail (log driver for local)
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Other (optional / Laravel defaults)
# ---------------------------------------------------------------------------
BROADCAST_CONNECTION=log

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"
